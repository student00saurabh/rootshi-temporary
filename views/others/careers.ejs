<% layout("/layouts/boilerplate") -%>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 transition-colors duration-300">
    <div class="py-16 sm:py-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <!-- Hero Section -->
            <div class="text-center mb-12">
                <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6">
                    <span class="text-cyan-600 dark:text-cyan-300">Career</span> Opportunities at RootShield
                </h1>
                <p class="text-xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto">
                    Join our mission to democratize cybersecurity education. Gain real-world experience, 
                    build your skills, and grow with us.
                </p>
            </div>

            <!-- Open Call Notice - Simplified -->
            <div class="bg-gradient-to-r from-cyan-50 to-blue-50 dark:from-cyan-900/20 dark:to-blue-900/20 rounded-2xl p-6 mb-12 border border-cyan-200 dark:border-cyan-800">
                <div class="flex flex-col md:flex-row items-center justify-between">
                    <div class="flex items-center mb-4 md:mb-0">
                        <div class="w-12 h-12 bg-gradient-to-br from-cyan-500 to-blue-500 rounded-xl flex items-center justify-center mr-4">
                            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-gray-900 dark:text-white">Open Applications</h3>
                            <p class="text-sm text-gray-600 dark:text-gray-400">
                                We're always looking for passionate learners to join our team
                            </p>
                        </div>
                    </div>
                    <div class="bg-white dark:bg-gray-800 px-4 py-2 rounded-lg border border-cyan-300 dark:border-cyan-600">
                        <span class="text-sm font-medium text-cyan-700 dark:text-cyan-300">
                            Rolling Applications • No Stipend
                        </span>
                    </div>
                </div>
            </div>

            <!-- Simplified Main Content - No Filters, No Job Listings -->
            <div class="max-w-4xl mx-auto">
                <!-- Call to Action Card -->
                <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden shadow-lg mb-10">
                    <div class="p-8 md:p-10 text-center">
                        <div class="w-20 h-20 bg-gradient-to-br from-cyan-500 to-blue-500 rounded-2xl flex items-center justify-center mx-auto mb-6">
                            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
                            Want to join us?
                        </h2>
                        <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mb-8">
                            Whether you're a developer, designer, or cybersecurity enthusiast — 
                            we'd love to hear from you. Share your resume and tell us why you want to grow with RootShield.
                        </p>
                        <div class="flex flex-col sm:flex-row gap-4 justify-center">
                            <a href="mailto:info@rootshield.in?subject=Application to join RootShield&body=Dear RootShield Team,%0D%0A%0D%0APlease find my resume attached.%0D%0A%0D%0AMy skills/portfolio: %0D%0AWhy I want to join: %0D%0A%0D%0AThank you!" 
                               class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-cyan-500 to-blue-500 text-white font-semibold rounded-xl hover:from-cyan-600 hover:to-blue-600 transition-all duration-300 transform hover:-translate-y-0.5 shadow-lg">
                                ✉️ Send Your Resume
                                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                                </svg>
                            </a>
                            <a href="#contact" 
                               class="inline-flex items-center justify-center px-8 py-4 border-2 border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-semibold rounded-xl hover:border-cyan-500 hover:text-cyan-600 dark:hover:text-cyan-400 transition-all duration-300">
                                📞 Contact Us
                            </a>
                        </div>
                    </div>
                </div>

                <!-- What We Look For Section -->
                <div class="grid md:grid-cols-3 gap-6 mb-12">
                    <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700 text-center">
                        <div class="w-14 h-14 bg-cyan-100 dark:bg-cyan-900/50 rounded-xl flex items-center justify-center mx-auto mb-4">
                            <svg class="w-7 h-7 text-cyan-600 dark:text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                            </svg>
                        </div>
                        <h3 class="font-bold text-gray-900 dark:text-white mb-2">Passion to Learn</h3>
                        <p class="text-gray-600 dark:text-gray-400 text-sm">
                            Curiosity and eagerness to grow matter more than experience
                        </p>
                    </div>
                    <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700 text-center">
                        <div class="w-14 h-14 bg-blue-100 dark:bg-blue-900/50 rounded-xl flex items-center justify-center mx-auto mb-4">
                            <svg class="w-7 h-7 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                            </svg>
                        </div>
                        <h3 class="font-bold text-gray-900 dark:text-white mb-2">Problem Solving</h3>
                        <p class="text-gray-600 dark:text-gray-400 text-sm">
                            Ability to think creatively and tackle challenges head-on
                        </p>
                    </div>
                    <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700 text-center">
                        <div class="w-14 h-14 bg-purple-100 dark:bg-purple-900/50 rounded-xl flex items-center justify-center mx-auto mb-4">
                            <svg class="w-7 h-7 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                            </svg>
                        </div>
                        <h3 class="font-bold text-gray-900 dark:text-white mb-2">Team Spirit</h3>
                        <p class="text-gray-600 dark:text-gray-400 text-sm">
                            Collaborate, share knowledge, and help others succeed
                        </p>
                    </div>
                </div>

                <!-- How It Works -->
                <div class="bg-gradient-to-r from-gray-50 to-gray-100 dark:from-gray-800/50 dark:to-gray-800/30 rounded-xl p-8 mb-12">
                    <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-6 text-center">How It Works</h3>
                    <div class="grid md:grid-cols-3 gap-8">
                        <div class="text-center">
                            <div class="w-12 h-12 bg-cyan-500 text-white rounded-full flex items-center justify-center text-xl font-bold mx-auto mb-3">1</div>
                            <h4 class="font-semibold text-gray-900 dark:text-white mb-2">Share Your Resume</h4>
                            <p class="text-gray-600 dark:text-gray-400 text-sm">Email your resume and portfolio to our team</p>
                        </div>
                        <div class="text-center">
                            <div class="w-12 h-12 bg-cyan-500 text-white rounded-full flex items-center justify-center text-xl font-bold mx-auto mb-3">2</div>
                            <h4 class="font-semibold text-gray-900 dark:text-white mb-2">Quick Review</h4>
                            <p class="text-gray-600 dark:text-gray-400 text-sm">We'll review your application and get back to you</p>
                        </div>
                        <div class="text-center">
                            <div class="w-12 h-12 bg-cyan-500 text-white rounded-full flex items-center justify-center text-xl font-bold mx-auto mb-3">3</div>
                            <h4 class="font-semibold text-gray-900 dark:text-white mb-2">Start Your Journey</h4>
                            <p class="text-gray-600 dark:text-gray-400 text-sm">Join us and begin learning by building real projects</p>
                        </div>
                    </div>
                </div>

                <!-- Contact Section -->
                <div id="contact" class="bg-white dark:bg-gray-800 rounded-xl p-8 border border-gray-200 dark:border-gray-700 mb-8">
                    <div class="text-center mb-6">
                        <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Get in Touch</h3>
                        <p class="text-gray-600 dark:text-gray-400">Have questions? Reach out to us directly.</p>
                    </div>
                    <div class="flex flex-col md:flex-row justify-center gap-8">
                        <div class="flex items-center justify-center">
                            <div class="w-10 h-10 bg-cyan-100 dark:bg-cyan-900/50 rounded-full flex items-center justify-center mr-3">
                                <svg class="w-5 h-5 text-cyan-600 dark:text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                </svg>
                            </div>
                            <div>
                                <p class="text-sm text-gray-500 dark:text-gray-400">Email us at</p>
                                <a href="mailto:info@rootshield.in" class="text-cyan-600 dark:text-cyan-300 font-medium hover:underline">info@rootshield.in</a>
                            </div>
                        </div>
                        <div class="flex items-center justify-center">
                            <div class="w-10 h-10 bg-cyan-100 dark:bg-cyan-900/50 rounded-full flex items-center justify-center mr-3">
                                <svg class="w-5 h-5 text-cyan-600 dark:text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.66 0 3-4 3-9s-1.34-9-3-9m0 18c-1.66 0-3-4-3-9s1.34-9 3-9"/>
                                </svg>
                            </div>
                            <div>
                                <p class="text-sm text-gray-500 dark:text-gray-400">Website</p>
                                <a href="#" class="text-cyan-600 dark:text-cyan-300 font-medium hover:underline">www.rootshield.in</a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Note -->
                <div class="text-center text-sm text-gray-500 dark:text-gray-400 border-t border-gray-200 dark:border-gray-700 pt-8">
                    <p>RootShield is an equal opportunity organization. We celebrate diversity and are committed to creating an inclusive environment for all.</p>
                </div>
            </div>
        </div>
    </div>
</div>